# ─── BACKEND (API FastAPI) ───────────────────────────────────
PORT=8000

# ─── IA (Google Gemini) ──────────────────────────────────────
AI_API_KEY=sua_chave_aqui        # chave do Gemini — OBRIGATÓRIA em prod (painel do Render); NUNCA commitar
AI_MODEL=gemini-3.5-flash        # modelo rápido/barato (confirmar versão atual na doc do Gemini)

# ─── CORS ────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ─── DATASET VÍSENT ──────────────────────────────────────────
VISENT_DATASET_PATH=./dataset/processed/concentracao.parquet

# ─── FRONTEND (Vite) ─────────────────────────────────────────
VITE_API_URL=http://localhost:8000

